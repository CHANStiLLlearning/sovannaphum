// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsArticle {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  date        String
  description String   @default("Discover the latest updates, achievements, and upcoming events in our school community.")
  createdAt   DateTime @default(now())
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  location    String
  date        String
  image       String?
  createdAt   DateTime @default(now())
}

model Teacher {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  subject     String
  nationality String   @default("Cambodian")
  image       String?
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slide {
  id               Int      @id @default(autoincrement())
  image            String
  tag              String
  title            String
  description      String
  iconName         String   @default("graduation-cap")
  primaryBtnText   String   @default("Learn More")
  primaryBtnLink   String   @default("/programs")
  secondaryBtnText String   @default("Contact Us")
  secondaryBtnLink String   @default("/contact")
  createdAt        DateTime @default(now())
}

model Program {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  path        String   @default("/programs")
  iconName    String   @default("book-open")
  colorClass  String   @default("bg-blue-50/70 text-blue-600 border border-blue-100/50")
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String?
  quote     String
  createdAt DateTime @default(now())
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer_kh String
  answer_en String
  createdAt DateTime @default(now())
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String
  logo      String
  createdAt DateTime @default(now())
}
